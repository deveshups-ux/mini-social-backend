<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Create User</title>
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
  </head>

  <body class="bg-gray-100 min-h-screen">
    <!-- Navbar -->
    <div class="flex justify-end p-5">
      <a
        href="/logout"
        class="bg-red-500 text-white px-4 py-2 rounded-lg hover:bg-red-600"
      >
        Logout
      </a>
    </div>

    <!-- Main Container -->
    <div class="max-w-2xl mx-auto bg-white p-8 rounded-xl shadow-lg">
      <p class="text-gray-500 mb-6">UPDATE YOUR POST</p>

      <!-- Form -->
      <form
        action="/update/<%= post._id %>"
        method="post"
        class="flex flex-col gap-4 mb-8"
      >
        <textarea
          name="content"
          class="border rounded-lg p-3 focus:outline-none focus:ring-2 focus:ring-blue-400"
          placeholder="What's in your mind..."
          rows="4"
        >
<%= post.content %></textarea
        >

        <input
          type="submit"
          value="Update"
          class="bg-yellow-500 text-black py-2 rounded-lg cursor-pointer hover:bg-blue-600"
        />
      </form>
    </div>
  </body>
</html>
