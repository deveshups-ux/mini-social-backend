<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Create User</title>
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
  </head>

  <body class="bg-gray-100 min-h-screen">
    <!-- Navbar -->
    <div class="flex justify-end p-5">
      <a
        href="/logout"
        class="bg-red-500 text-white px-4 py-2 rounded-lg hover:bg-red-600"
      >
        Logout
      </a>
    </div>

    <!-- Main Container -->
    <div class="max-w-2xl mx-auto bg-white p-8 rounded-xl shadow-lg">
      <h1 class="text-3xl font-bold mb-2 text-gray-800">
        Hello <%= user.username %> how are you👋
      </h1>
      <p class="text-gray-500 mb-6">YOU CAN CREATE A NEW POST</p>

      <!-- Form -->
      <form action="/post" method="post" class="flex flex-col gap-4 mb-8">
        <textarea
          name="content"
          class="border rounded-lg p-3 focus:outline-none focus:ring-2 focus:ring-blue-400"
          placeholder="What's in your mind..."
          rows="4"
        ></textarea>

        <input
          type="submit"
          value="Create New Post"
          class="bg-blue-500 text-white py-2 rounded-lg cursor-pointer hover:bg-blue-600"
        />
      </form>

      <!-- Posts Section -->
      <h3 class="text-xl font-semibold mb-4">YOUR POSTS</h3>

      <div class="space-y-4">
        <!-- Post Card -->
         <% user.posts.reverse().forEach(function(posts){ %>
             <div class="bg-gray-50 p-4 mb-4 rounded-lg border">
          <h4 class="font-semibold text-blue-700">@<%= user.username %></h4>

          <p class="text-gray-600 mt-2">
           <%= posts.content %>
          </p>
          <small> <%= posts.likes.length %> Likes</small>

          <div class="flex gap-4 mt-3">
            <a href="/like/<%= posts._id %>" class="text-blue-500 hover:underline">
              <%= posts.likes.indexOf(user._id) === -1 ? "Like" : "Dislike" %> 
            </a>
            <a href="/edit/<%= posts._id %>" class="text-green-500 hover:underline">Edit</a>
          </div>
        </div>
        <%})  %>
      </div>
    </div>
  </body>
</html>
