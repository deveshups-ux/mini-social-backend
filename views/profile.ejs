<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Create User</title>
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
  </head>

  <body class="bg-gray-100 min-h-screen">
    <!-- Navbar -->
    <div class="flex justify-end p-5">
      <a
        href="/logout"
        class="bg-red-500 text-white px-4 py-2 rounded-lg hover:bg-red-600"
      >
        Logout
      </a>
    </div>

    <!-- Main Container -->
   <div class="max-w-2xl mx-auto bg-white p-6 rounded-2xl shadow-md mt-6">

  <!-- Profile Section -->
  <div class="flex items-center gap-4 mb-6">
    <div class="w-20 h-20 overflow-hidden rounded-full border-2 border-blue-400">
      <img class="h-full w-full object-cover" src="/images/uploads/<%= user.profilepic %>" alt="">
    </div>

    <div>
      <h1 class="text-2xl font-bold text-gray-800">
        Hello <%= user.username %> 👋
      </h1>
      <p class="text-gray-500 text-sm">Welcome back!</p>
    </div>
  </div>

  <!-- Create Post -->
  <div class="mb-8">
    <p class="text-gray-600 mb-2 font-medium">Create a new post</p>

    <form action="/post" method="post" class="flex flex-col gap-3">
      <textarea
        name="content"
        class="border rounded-xl p-3 focus:outline-none focus:ring-2 focus:ring-blue-400 resize-none"
        placeholder="What's in your mind..."
        rows="3"
      ></textarea>

      <input
        type="submit"
        value="Post 🚀"
        class="bg-blue-500 text-white py-2 rounded-xl cursor-pointer hover:bg-blue-600 transition"
      />
    </form>
  </div>

  <!-- Posts Section -->
  <h3 class="text-lg font-semibold mb-4 text-gray-700">Your Posts</h3>

  <div class="space-y-4">
    <% [...user.posts].reverse().forEach(function(post){ %>

      <div class="bg-gray-50 p-4 rounded-xl border hover:shadow-sm transition">

        <div class="flex justify-between items-center">
          <h4 class="font-semibold text-blue-600">@<%= user.username %></h4>
          <small class="text-gray-400"><%= post.likes.length %> Likes</small>
        </div>

        <p class="text-gray-700 mt-2 leading-relaxed">
          <%= post.content %>
        </p>

        <div class="flex gap-6 mt-3 text-sm">
          <a href="/like/<%= post._id %>" class="text-blue-500 hover:underline">
            <%= post.likes.some(id => id.toString() === user._id.toString()) ? "💔 Dislike" : "❤️ Like" %>
          </a>

          <a href="/edit/<%= post._id %>" class="text-green-500 hover:underline">
            ✏️ Edit
          </a>
        </div>

      </div>

    <% }) %>
  </div>
</div>
  </body>
</html>
